---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Navbar } from '@slotra/ui';
import { HeroSection } from '../components/HeroSection';
import { SpotlightSection } from '../components/SpotlightSection';
import { FeatureRow } from '../components/FeatureRow';
import { StepsSection } from '../components/StepsSection';
import { SocialProofSection } from '../components/SocialProofSection';
import { APP_NAME } from '@slotra/utils';
---

<BaseLayout
  title={`${APP_NAME} — Free Scheduling Software for Philippine Businesses`}
  description="Slotra is a free scheduling platform for Philippine businesses. Automate bookings, reminders, and payments 24/7."
>
  <Navbar client:load />
  <HeroSection client:load />
  <SpotlightSection client:load />
  <FeatureRow client:load />
  <StepsSection client:load />
  <SocialProofSection client:load />
</BaseLayout>

