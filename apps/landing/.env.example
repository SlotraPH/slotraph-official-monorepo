# Landing app environment variables
# Copy this file to apps/landing/.env for local development.
#
# Get these values from Supabase Dashboard:
# 1. Open https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Project Settings -> API
#
# What you need:
# - VITE_SUPABASE_URL: the "Project URL"
# - VITE_SUPABASE_ANON_KEY: the "anon public" API key
#
# Do not use the service_role key here. This file is loaded by the client app.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Cloudflare Turnstile ──────────────────────────────────────
# Get your site key from: https://dash.cloudflare.com → Turnstile
# For local testing use: 1x00000000000000000000AA (always-pass test key)
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Optional local feature flag used by the landing app.
IN_DEVELOPMENT=true
