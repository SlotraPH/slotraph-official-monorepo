---
import BaseLayout from './BaseLayout.astro';
import { Navbar } from '@slotra/ui';
import { Footer } from '../components/Footer';
import { ScrollToTop } from '../components/ScrollToTop';
import { AnalyticsProvider } from '../components/AnalyticsProvider';
import { CookieBanner } from '../components/CookieBanner';
import { DevBanner } from '../components/DevBanner';
import { Toaster } from 'sileo';
import { IN_DEVELOPMENT } from '../config';
import { APP_NAME } from '@slotra/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  alternatePath?: string;
}

const {
  title = `${APP_NAME} — Free Scheduling Software for Philippine Businesses`,
  description = 'Slotra is a free scheduling platform for Philippine businesses. Automate bookings, reminders, and payments 24/7.',
  locale = 'en',
  alternatePath = locale === 'en' ? '/tl' : '/',
} = Astro.props;

const canonicalBase = 'https://slotra.ph';
const enUrl = `${canonicalBase}${locale === 'tl' ? alternatePath : Astro.url.pathname}`;
const tlUrl = `${canonicalBase}${locale === 'tl' ? Astro.url.pathname : alternatePath}`;
---

<BaseLayout title={title} description={description} lang={locale}>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="tl" href={tlUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
  </Fragment>
  {IN_DEVELOPMENT && <DevBanner client:load />}
  <Navbar
    loginHref={locale === 'tl' ? '/tl/demo' : '/demo'}
    inDevelopment={IN_DEVELOPMENT}
    locale={locale}
    alternatePath={alternatePath}
    client:load
  />
  <slot />
  <Footer client:load />
  <ScrollToTop client:load />
  <AnalyticsProvider locale={locale} client:load />
  <CookieBanner locale={locale} client:load />
  <Toaster
    position="bottom-left"
    options={{
      fill: "#0f1f2e",
      roundness: 14,
      styles: {
        title: "!text-white",
        description: "!text-white/60",
        badge: "!bg-white/10",
      },
    }}
    client:load
  />
</BaseLayout>
