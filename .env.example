# ============================================================
# Slotra — Global Environment Variables
# Copy this file to .env and fill in your values.
# Each app may also have its own .env for app-specific vars.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Apps (Vite prefix required for client-side access) ───────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Cloudflare Turnstile ──────────────────────────────────────
# Get these from: https://dash.cloudflare.com → Turnstile → Add Site
# Use widget type: Invisible
# For local testing: Site Key=1x00000000000000000000AA, Secret Key=1x0000000000000000000000000000000AA
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
# TURNSTILE_SECRET_KEY goes in Supabase Edge Function secrets (not here)

# ── App URLs ─────────────────────────────────────────────────
VITE_APP_URL=http://localhost:4321        # landing (Astro)
VITE_WEB_APP_URL=http://localhost:5173    # web-app (Vite/React)
